{
    "config": {
        "service_url": "http://localhost:8080/rasdaman/ows",
        "tmp_directory": "/tmp",
        "default_crs": "http://www.opengis.net/def/crs/EPSG/0/4326",
        "mock": false,
        "automated": true
    },
    "input": {
        "coverage_id": "DWD_5min_4326",
        "paths": ["./dwd-geotiff/dwd-geotiff-epsg4326/YW_2017.002_*.tif"],
        "wms_import": false,
        "pyramid": false,
        "coverage_type": "grid",
        "nodata": -9,
        "pixel_size": [0.01, 0.01],
        "origin": [5.0, 47.0],
        "axis_order": ["lon", "lat"] 
    },
    "recipe": {
        "name": "time_series_regular",
        "options": {
            "time_start": "2022-01-01T00:00:00Z",
            "time_step": "5 minutes",
            "time_format": "auto",
            "time_parameter": {
                "filename": {
                    "regex": "YW_2017\\.002_(\\d{8}_\\d{4})\\.tif",
                    "group": 1
                },
                "datetime_format": "YYYYMMDD_HHmm"
            },
            "time_crs": "http://localhost:8080/def/crs/OGC/0/AnsiDate",
            "tiling": "ALIGNED [0:2, 0:256, 0:256]"
        }
    }
}
